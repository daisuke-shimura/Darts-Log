<div class="position-relative" data-controller="hole target">
  <div class="board position-absolute top-0 ms-2" data-action="click->hole#click">
    <% cache "dartboard" do %>
      <%= render "records/board/out" %>
      <%= render "records/board/double" %>
      <%= render "records/board/outer-single" %>
      <%= render "records/board/triple" %>
      <%= render "records/board/inner-single" %>
      <%= render "records/board/bull" %>
    <% end %>
  </div>

  <%= render "records/result" %>
  
  <%= render "records/modal-target-form" %>

  <div class="position-absolute top-0 end-0 p-1">
    <div class="score-box">
      <%= @game.start_score %>
    </div>
    <div class="round-box mt-2 ms-auto">
      <% (1..10).each do |n| %>
      <div class="d-flex">
        <span class="ps-2 py-1 round-label">R<%= n %></span>
        <span class="pe-3 py-1 round-score">-</span>
      </div>
      <% end %>
    </div>
  </div>
</div>
