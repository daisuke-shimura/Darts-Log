<turbo-frame id="new-modal"></turbo-frame>

<% if flash.any? %>
  <div class="toast-container position-fixed top-0 start-0 p-3">
    <% flash.each do |key, message| %>
      <div class="toast align-items-center text-bg-<%= key == "notice" ? "success" : "danger" %> border-0"
          role="alert"
          data-bs-delay="2000"
          data-bs-autohide="true">
        <div class="d-flex">
          <div class="toast-body">
            <%= message %>
          </div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<div class="container mt-4">
  <div class="row">
    <!-- 計測 -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h2 class="card-title mb-3">計測</h2>
          <% if user_signed_in? %>
            <%= link_to "計測画面", records_path, class: "btn btn-primary" %>
          <% else %>
            <h5>ユーザ選択</h5>
            <%= form_with url: login_path, method: :post do |f| %>
              <div class="mb-3">
                <%= f.select :user_id,
                      options_from_collection_for_select(@users, :id, :name),
                      { prompt: "ユーザを選択" },
                      { class: "form-select" , required: true } %>
              </div>
                <%= f.submit "決定", class: "btn btn-primary" %>
            <% end %>
          <% end %>

          <hr>

          <p class="text-muted mb-1">
            未登録の方
            <%= link_to "登録", new_user_path, data: { turbo_frame: "new-modal" }, class: "btn btn-outline-success btn-sm" %>
          </p>
        </div>
      </div>
    </div>

    <!-- データ閲覧 -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h2 class="card-title">データ閲覧</h2>

          <%= link_to "データ閲覧",
                logs_path,
                class: "btn btn-outline-primary mt-2" %>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <h2 class="card-title">ユーザ管理</h2>
      <%= link_to "ユーザ一覧", users_path, class: "btn btn-outline-secondary mt-2" %>
    </div>
  </div>
</div>
