<turbo-frame id="modal">
  <div class="modal-backdrop fade show" style="background-color: rgba(0,0,0,0.5);"></div>
  <div class="modal fade show" style="display:block;" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="width:100%; max-width:420px;">
      <div class="modal-content">

        <div class="modal-header">
          <h5 class="modal-title">ユーザー編集</h5>

          <%= link_to " ", users_path, class: "btn-close", aria: { label: "閉じる" } %>
        </div>

        <div class="modal-body">
          <%= form_with model: @user, data: { turbo_frame: "_top" }, local: true, class: "needs-validation" do |f| %>

            <div class="mb-3">
              <%= f.label :name, "名前", class: "form-label" %>
              <%= f.text_field :name, required: true, class: "form-control", autofocus: true %>
            </div>

            <div class="row gx-3">
              <div class="col-6 mb-3">
                <%= f.label :gender, "性別", class: "form-label" %>
                <%= f.select :gender,
                      options_for_select([["男性", "male"], ["女性", "female"], ["その他", "other"]], @user&.gender),
                      { include_blank: "選択してください" },
                      { class: "form-select" } %>
              </div>

              <div class="col-6 mb-3">
                <%= f.label :birthday, "生年月日", class: "form-label" %>
                <%= f.date_field :birthday, class: "form-control" %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :experience, "ダーツ経験", class: "form-label" %>
              <%= f.text_area :experience, class: "form-control", rows: 4 %>
            </div>

            <div class="modal-footer">
              <%= f.submit "更新", class: "btn btn-primary" %>
              <%= link_to "キャンセル", users_path, class: "btn btn-secondary", data: { turbo_frame: "_top" } %>
            </div>

          <% end %>
        </div>
      </div>
    </div>
  </div>
</turbo-frame>
