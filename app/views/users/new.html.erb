<h1>新規登録</h1>

<% if @user && @user.errors.any? %>
  <div id="error_explanation">
    <h2><%= pluralize(@user.errors.count, "件のエラー") %>で保存できませんでした：</h2>
    <ul>
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: @user, local: true) do |f| %>
  <div class="field">
    <%= f.label :name, "名前" %><br>
    <%= f.text_field :name, required: true %>
  </div>

  <div class="field">
    <%= f.label :gender, "性別" %><br>
    <%= f.select :gender, options_for_select([["男性", "male"], ["女性", "female"], ["その他", "other"]], @user&.gender), include_blank: "選択してください" %>
  </div>

  <div class="field">
    <%= f.label :birthday, "生年月日" %><br>
    <%= f.date_field :birthday %>
  </div>

  <div class="field">
    <%= f.label :experience, "ダーツ経験" %><br>
    <%= f.text_area :experience %>
  </div>

  <div class="actions">
    <%= f.submit "登録する" %>
    <%= link_to "戻る", root_path %>
  </div>
<% end %>

