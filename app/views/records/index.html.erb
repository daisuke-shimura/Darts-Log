<div data-controller="hole">
  <div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="liveToast" class="toast align-items-center text-bg-success border-0" role="alert">
      <div class="d-flex">
        <div class="toast-body">
          保存しました
        </div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
    </div>
  </div>
  <div class="bord">
    <!--%= render "bull" %-->
    <%= render "inner-single" %>
  </div>
  <div class="d-flex">
    <button data-action="click->hole#submit">確定</button>
    <ul>
      <li>1投目：<span data-hole-target="output"></span></li>
      <li>2投目：<span data-hole-target="output"></span></li>
      <li>3投目：<span data-hole-target="output"></span></li>
    </ul>
  </div>
</div>