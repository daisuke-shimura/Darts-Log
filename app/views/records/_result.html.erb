<div id="fixedForm" data-controller="result" class="fixed-form">
  <div class="fixed-form-inner">
    <button class="target-display" data-bs-toggle="modal" data-bs-target="#targetModal">
      <input type="hidden" value="<%= @defalut_target %>" data-<%= js_controller %>-target="targetInput">
      <div class="target-label">TARGET</div>
      <div class="target-name" data-target-target="name"><%= @defalut_target_name %></div>
    </button>

    <ul class="result-list">
      <li>1投目：<span data-<%= js_controller %>-target="output"></span></li>
      <li>2投目：<span data-<%= js_controller %>-target="output"></span></li>
      <li>3投目：<span data-<%= js_controller %>-target="output"></span></li>
    </ul>

    <%= render "records/flash-message" %>
    <button disabled class="cansel-btn btn btn-secondary rounded-pill" data-action="click-><%= js_controller %>#cancel" data-<%= js_controller %>-target="cancelBtn">
      キャンセル
    </button>
    <button disabled class="submit-btn btn btn-primary rounded-pill" data-action="click-><%= js_controller %>#submit" data-<%= js_controller %>-target="submitBtn">
      確定
    </button>
  </div>
</div>
